:root {
  --ink: #00352c;
  --teal: #00a982;
  --teal-dark: #008d6d;
  --mint: #e9faf6;
  --cyan: #d8f8f6;
  --green: #e6fbdc;
  --yellow: #fff3a6;
  --pink: #fae6e8;
  --purple: #d9d5ff;
  --paper: #ffffff;
  --muted: #65716e;
  --border: #073b32;
  --container: 1180px;
  --radius: 18px;
}

*,
*::before,
*::after {
  box-sizing: border-box;
  min-width: 0;
}

html {
  max-width: 100%;
  scroll-behavior: smooth;
}

body {
  max-width: 100%;
  margin: 0;
  color: var(--ink);
  background: var(--paper);
  font-family: "Inter", Arial, sans-serif;
  line-height: 1.5;
}

main,
section,
header,
footer {
  max-width: 100%;
}

figure {
  margin: 0;
}

img {
  display: block;
  max-width: 100%;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

.container {
  width: 100%;
  max-width: var(--container);
  margin-inline: auto;
  padding-inline: 24px;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(14px);
}

.header-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 32px;
  min-height: 76px;
}

.brand,
.footer-brand {
  display: inline-flex;
  width: max-content;
  align-items: center;
}

.brand img,
.footer-brand img {
  display: block;
  width: 112px;
  height: auto;
}

.main-nav {
  display: flex;
  align-items: center;
  gap: 30px;
  color: var(--ink);
  font-size: 14px;
  font-weight: 600;
}

.main-nav a,
.text-link {
  transition: color 180ms ease;
}

.main-nav a:hover,
.text-link:hover {
  color: var(--teal);
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20px;
  color: var(--ink);
  font-size: 14px;
  font-weight: 700;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0 22px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-weight: 700;
  box-shadow: 0 3px 0 var(--border);
  transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease, color 160ms ease;
}

.button:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 0 var(--border);
}

.button:active {
  transform: translateY(2px);
  box-shadow: 0 1px 0 var(--border);
}

.button:focus-visible,
.main-nav a:focus-visible,
.text-link:focus-visible,
.social-links a:focus-visible,
.footer-column a:focus-visible {
  outline: 3px solid rgba(0, 169, 130, 0.38);
  outline-offset: 4px;
}

.button-primary {
  color: #ffffff;
  background: var(--teal);
}

.button-primary:hover {
  background: var(--teal-dark);
}

.button-outline {
  color: var(--ink);
  background: #ffffff;
}

.menu-toggle {
  display: none;
  place-content: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: #ffffff;
  cursor: pointer;
}

.menu-toggle span {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--ink);
  transition: transform 180ms ease, opacity 180ms ease;
}

.menu-toggle.is-open span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.menu-toggle.is-open span:nth-child(2) {
  opacity: 0;
}

.menu-toggle.is-open span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

.hero {
  padding: 72px 0 62px;
}

.hero-inner {
  text-align: center;
}

.hero h1 {
  max-width: 820px;
  margin: 0 auto;
  font-size: clamp(46px, 6vw, 82px);
  line-height: 1.02;
  letter-spacing: 0;
  overflow-wrap: break-word;
}

.hero-copy {
  max-width: 590px;
  margin: 26px auto 0;
  color: var(--muted);
  font-size: 18px;
  font-weight: 500;
}

.button-row {
  display: flex;
  justify-content: center;
  gap: 14px;
  max-width: 100%;
  margin-top: 28px;
}

.webinar-stage {
  width: 100%;
  max-width: 940px;
  margin: 66px auto 0;
  overflow: hidden;
  border: 3px solid var(--ink);
  border-radius: 24px;
  background: var(--ink);
  box-shadow: 0 18px 50px rgba(0, 53, 44, 0.12);
}

.webinar-stage img {
  width: 100%;
  height: auto;
}

.social-proof {
  padding: 46px 0 96px;
  text-align: center;
}

.avatar-stack {
  display: flex;
  justify-content: center;
}

.avatar-stack span {
  width: 34px;
  height: 34px;
  margin-left: -8px;
  border: 3px solid #ffffff;
  border-radius: 50%;
  background: linear-gradient(135deg, #b9f1e6, #ffdbcb);
  box-shadow: 0 4px 16px rgba(0, 53, 44, 0.12);
}

.avatar-stack span:nth-child(2) {
  background: linear-gradient(135deg, #cfcaff, #f8e8a5);
}

.avatar-stack span:nth-child(3) {
  background: linear-gradient(135deg, #d9f8d1, #c7f4ff);
}

.social-proof h2,
.ai-panel h2,
.engagement h2,
.feature-cloud h2,
.cta-card h2 {
  max-width: 100%;
  margin: 24px auto 0;
  font-size: clamp(34px, 4.5vw, 58px);
  line-height: 1.08;
  letter-spacing: 0;
  overflow-wrap: break-word;
}

.logo-row {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  align-items: center;
  gap: 30px;
  width: 100%;
  max-width: 100%;
  padding: 0;
  margin: 52px 0 0;
  list-style: none;
}

.logo-row li {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
}

.logo-row img {
  width: 100%;
  max-width: 150px;
  height: 38px;
  object-fit: contain;
  opacity: 0.5;
  transition: opacity 180ms ease;
}

.logo-row img:hover {
  opacity: 0.82;
}

.new-ribbon {
  display: flex;
  width: 100%;
  justify-content: space-around;
  align-items: center;
  height: 54px;
  margin-left: 0;
  overflow: hidden;
  color: var(--teal);
  background: var(--mint);
  font-size: 13px;
  font-weight: 800;
  transform: rotate(-2deg);
  transform-origin: center;
}

.ai-section {
  padding: 58px 0 110px;
  overflow: clip;
  background-image: radial-gradient(#dceeea 1px, transparent 1px);
  background-size: 18px 18px;
}

.ai-panel {
  width: 100%;
  max-width: 100%;
  padding: 70px 24px 40px;
  border: 1px solid #dceeea;
  border-radius: 28px;
  text-align: center;
  background: rgba(255, 255, 255, 0.88);
}

.section-heading p {
  max-width: 660px;
  margin: 22px auto 0;
  color: var(--muted);
  font-size: 17px;
  font-weight: 500;
}

.ai-panel img {
  width: min(430px, 100%);
  margin: 44px auto 0;
}

.engagement {
  padding: 118px 0;
}

.engagement > .container > h2,
.feature-cloud h2 {
  text-align: center;
}

.engagement-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
  align-items: start;
  gap: 74px;
  margin-top: 72px;
}

.engagement-layout > * {
  min-width: 0;
}

.feature-tabs {
  display: grid;
  gap: 8px;
}

.feature-tab {
  position: relative;
  padding: 18px 20px 18px 34px;
  border: 0;
  border-radius: 10px;
  color: #8e9996;
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.feature-tab::before {
  content: "";
  position: absolute;
  inset: 16px auto 16px 0;
  width: 4px;
  border-radius: 4px;
  background: transparent;
}

.feature-tab strong,
.feature-tab span {
  display: block;
}

.feature-tab strong {
  font-size: 17px;
}

.feature-tab span {
  margin-top: 5px;
  font-size: 14px;
}

.feature-tab.is-active {
  color: var(--ink);
  background: #f8fbfa;
}

.feature-tab.is-active::before {
  background: var(--ink);
}

.engagement-preview {
  position: sticky;
  top: 96px;
  margin: 0;
}

.engagement-preview img {
  width: 100%;
  height: auto;
}

.feature-cloud {
  padding: 100px 0 120px;
}

.feature-cloud-image {
  width: 100%;
  max-width: 990px;
  min-width: 0;
  margin: 66px auto 0;
}

.feature-cloud-image img {
  width: 100%;
  max-width: 100%;
  height: auto;
}

.final-cta {
  padding: 90px 0;
  background: var(--mint);
}

.cta-card {
  max-width: 840px;
  padding: 70px 30px;
  border: 3px solid var(--ink);
  border-radius: 24px;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 7px 0 var(--ink);
}

.cta-card mark {
  padding: 0 10px;
  border-radius: 12px;
  color: inherit;
  background: var(--green);
}

.cta-card em {
  padding: 0 10px;
  border-radius: 12px;
  font-style: normal;
  background: var(--purple);
}

.cta-card p {
  margin: 28px auto 0;
  color: var(--muted);
  font-weight: 500;
}

.site-footer {
  padding: 76px 0 86px;
  color: #ffffff;
  background: var(--ink);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr repeat(3, 1fr);
  gap: 70px;
}

.footer-brand {
  color: #4de2bd;
}

.site-footer p,
.site-footer a {
  color: rgba(255, 255, 255, 0.72);
}

.site-footer h2 {
  margin: 0 0 20px;
  color: #ffffff;
  font-size: 14px;
}

.footer-column a {
  display: block;
  margin-top: 12px;
  font-size: 13px;
}

.social-links {
  display: flex;
  gap: 18px;
  margin-top: 28px;
}

.social-links a {
  display: grid;
  place-items: center;
  width: 32px;
  height: 32px;
  border: 1px solid rgba(255, 255, 255, 0.34);
  border-radius: 50%;
  transition: border-color 180ms ease, transform 180ms ease;
}

.social-links a:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.8);
}

.social-links img {
  width: 15px;
  height: 15px;
}

@media (max-width: 991px) {
  .header-row {
    grid-template-columns: 1fr auto;
  }

  .main-nav,
  .header-actions {
    display: none;
  }

  .menu-toggle {
    display: grid;
  }

  .site-header.is-open .main-nav {
    position: absolute;
    inset: 76px 24px auto;
    display: grid;
    gap: 18px;
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #ffffff;
    box-shadow: 0 20px 60px rgba(0, 53, 44, 0.14);
  }

  .logo-row {
    grid-template-columns: repeat(3, 1fr);
  }

  .engagement-layout {
    grid-template-columns: 1fr;
  }

  .engagement-preview {
    position: static;
    order: -1;
  }


  .footer-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .container {
    padding-inline: 16px;
  }

  .hero {
    padding-top: 54px;
  }

  .hero h1 {
    font-size: 48px;
  }

  .button-row {
    flex-wrap: wrap;
  }

  .webinar-stage {
    margin-top: 46px;
    border-radius: 16px;
  }

  .social-proof,
  .engagement,
  .feature-cloud {
    padding-block: 80px;
  }


  .footer-grid {
    gap: 44px 24px;
  }
}

@media (max-width: 500px) {
  .hero h1 {
    max-width: 300px;
    font-size: 28px;
    line-height: 1.08;
  }

  .social-proof h2,
  .ai-panel h2,
  .engagement h2,
  .feature-cloud h2,
  .cta-card h2 {
    max-width: 300px;
    font-size: 28px;
    line-height: 1.12;
  }

  .hero-copy {
    max-width: 300px;
    font-size: 16px;
  }

  .section-heading p,
  .cta-card p {
    max-width: 300px;
    font-size: 15px;
  }

  .button {
    min-height: 42px;
    padding-inline: 16px;
    font-size: 14px;
  }

  .button {
    width: auto;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .webinar-stage,
  .feature-cloud-image,
  .engagement-preview {
    width: 100%;
    max-width: 300px;
    margin-inline: auto;
  }

  .cta-card {
    width: 100%;
    max-width: 300px;
    padding: 42px 16px;
  }

  .ai-panel img {
    width: 100%;
    max-width: 300px;
  }

  .logo-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 18px;
  }

  .logo-row img {
    height: 34px;
  }

  .ai-panel {
    padding-inline: 16px;
  }

  .new-ribbon {
    width: 100%;
    margin-left: 0;
  }

  .engagement-layout {
    gap: 36px;
  }


  .footer-grid {
    grid-template-columns: 1fr;
  }
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
